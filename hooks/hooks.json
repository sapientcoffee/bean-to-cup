{
  "AfterTool": [
    {
      "matcher": ".*write_file|.*replace",
      "hooks": {
        "lint-on-change": {
          "type": "command",
          "command": "${extensionPath}/hooks/lint-on-change.sh",
          "timeout": 30000,
          "description": "Runs the relevant lint test after a file is modified."
        }
      }
    }
  ],
  "SessionStart": [
    {
      "matcher": "startup",
      "hooks": {
        "coffee-and-git": {
          "type": "command",
          "command": "${extensionPath}/hooks/coffee-and-git.sh",
          "description": "Provides a coffee tip and git history at the start of the session"
        },
        "git-status": {
          "type": "command",
          "command": "${extensionPath}/hooks/git-status.sh",
          "description": "Injects git status into the context"
        }
      }
    }
  ],
  "AfterAgent": [
    {
      "matcher": ".*",
      "hooks": {
        "implementation-loop": {
          "type": "command",
          "command": "${extensionPath}/hooks/stop-loop.sh",
          "description": "The Ralph infinite loop mechanism"
        }
      }
    }
  ]
}
